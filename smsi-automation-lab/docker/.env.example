# =============================================================
# CISO Assistant — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE JAMAIS committer le fichier .env
# =============================================================

# Base de données PostgreSQL
DB_NAME=ciso
DB_USER=ciso
DB_PASSWORD=REMPLACER_PAR_UN_MOT_DE_PASSE_FORT

# Django (générer avec : python -c "import secrets; print(secrets.token_hex(50))")
SECRET_KEY=REMPLACER_PAR_UNE_CLE_ALEATOIRE_DE_100_CARACTERES_MINIMUM
ALLOWED_HOSTS=localhost,127.0.0.1

# CORS (frontend autorisé à appeler le backend)
CORS_ORIGINS=http://localhost:3000

# Compte superadmin CISO Assistant (créé au premier démarrage)
SUPERUSER_EMAIL=admin@techshop.fr
SUPERUSER_PASSWORD=changeme_motdepasse_admin

# URL du frontend (pour les redirections)
FRONTEND_ORIGIN=http://localhost:3000
